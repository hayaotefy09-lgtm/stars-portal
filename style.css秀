/* 
   STARS DESIGN SYSTEM v4.0 - TOTAL RESTORATION 
   Colors: Baby Pink & Magenta (Final Seal Parity)
*/

:root {
    --stars-pink: #e75498;
    --stars-pink-light: #fff5f9;
    --stars-pink-border: #fce4ec;
    --stars-magenta: #e84393;
    --stars-bg: #f8fafc;
    --text-dark: #1e293b;
    --text-muted: #94a3b8;
    --font-heading: 'Outfit', sans-serif;
    --font-body: 'Inter', sans-serif;
}

* { box-sizing: border-box; }
body {
    margin: 0;
    font-family: var(--font-body);
    background-color: var(--stars-bg);
    color: var(--text-dark);
}

/* --- AUTHENTICATION GATEWAY (720px Wide) --- */
.auth-gateway-wrap {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--stars-pink-light) 0%, #ffffff 100%);
}

.auth-card {
    background: #fff;
    padding: 5rem 6.5rem;
    border-radius: 40px;
    box-shadow: 0 45px 120px -25px rgba(232, 67, 147, 0.12);
    width: 720px;
    max-width: 95%;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    text-align: center;
}

/* --- DASHBOARD ARCHITECTURE (THE MISSING PIECE) --- */
#app-container {
    display: flex;
    height: 100vh;
    width: 100vw;
    overflow: hidden;
}

/* Sidebar */
.sidebar {
    width: 280px;
    background: white;
    border-right: 1px solid var(--stars-pink-border);
    display: flex;
    flex-direction: column;
    padding: 2rem 0;
    flex-shrink: 0;
}

.sidebar-header {
    padding: 0 2rem;
    margin-bottom: 2.5rem;
    text-align: center;
}

.acronym {
    font-size: 0.7rem;
    color: var(--text-muted);
    line-height: 1.4;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-top: 1rem;
}

.acronym span { color: var(--stars-magenta); font-weight: 800; }

.nav-links {
    list-style: none;
    padding: 0;
    margin: 0;
}

.nav-links li {
    padding: 1rem 2rem;
    font-weight: 600;
    color: #64748b;
    cursor: pointer;
    transition: all 0.2s;
    border-right: 4px solid transparent;
}

.nav-links li:hover {
    background: var(--stars-pink-light);
    color: var(--stars-magenta);
}

.nav-links li.active {
    background: var(--stars-pink-light);
    color: var(--stars-magenta);
    border-right-color: var(--stars-magenta);
}

/* Main Content Area */
.main-content {
    flex: 1;
    overflow-y: auto;
    padding: 3rem 4rem;
    background: white;
}

.page { display: none; }
.page.active { display: block; animation: fadeIn 0.4s ease; }

@keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
}

/* --- DASHBOARD COMPONENTS --- */
.main-header-block h1 {
    font-family: var(--font-heading);
    font-size: 2.4rem;
    color: var(--stars-magenta);
    margin: 0;
}

.section-title {
    font-size: 0.8rem;
    font-weight: 800;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin-bottom: 1.5rem;
}

.card-container {
    background: white;
    border: 1.5px solid var(--stars-pink-border);
    border-radius: 24px;
    padding: 2rem;
    transition: 0.3s;
}

.card-container:hover {
    transform: translateY(-5px);
    box-shadow: 0 15px 40px rgba(232, 67, 147, 0.08);
}

/* UTILITIES */
.btn {
    padding: 0.8rem 1.5rem;
    border-radius: 12px;
    font-weight: 700;
    cursor: pointer;
    transition: 0.2s;
    border: none;
    font-family: inherit;
}

.btn-primary { background: var(--stars-magenta); color: white; }
.btn-primary:hover { background: #d63031; transform: scale(1.02); }

.btn-outline {
    background: white;
    border: 1.5px solid var(--stars-pink-border);
    color: var(--stars-magenta);
}

.avatar {
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
}

/* Re-include the Auth Menu cards from portal logic */
.auth-menu-card {
    display: flex;
    align-items: center;
    width: 100%;
    padding: 1.25rem 1.5rem;
    margin-bottom: 1rem;
    background: white;
    border: 1.5px solid var(--stars-pink-border);
    border-radius: 20px;
    cursor: pointer;
    transition: all 0.3s;
    text-align: left;
}
